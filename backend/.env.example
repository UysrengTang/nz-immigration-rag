APP_NAME=NZ Immigration RAG
APP_VERSION=0.1.0
APP_ENV=development

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_BASE_URL=
OPENAI_EMBEDDING_DIMENSIONS=
EMBEDDING_BATCH_SIZE=64

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nz_immigration_rag
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

INGESTION_USER_AGENT=nz-immigration-rag/0.1 (+official-source-loader)
HTTP_TIMEOUT_SECONDS=30
CHUNK_SIZE_TOKENS=350
CHUNK_OVERLAP_TOKENS=40
VECTOR_TOP_K=12
RETRIEVAL_TOP_N=6

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=nz-immigration-rag
